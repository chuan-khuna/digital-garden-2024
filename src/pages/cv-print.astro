---
import BaseLayoutPrint from '@/layouts/BaseLayoutPrint.astro'
import { SITE } from '@/content/site.config.ts'

// layout
import PageLayout from '@/components/resume/layout/PageLayout.astro'
import Content from '@/components/resume/layout/Content.astro'
import WebWrapper from '@/components/resume/layout/WebWrapper.astro'

// sections
import PrintHeader from '@/components/resume/sections/print/Header.astro'
import Experiences from '@/components/resume/sections/Experiences.astro'
import Skills from '@/components/resume/sections/Skills.astro'
import Projects from '@/components/resume/sections/Projects.astro'
import Education from '@/components/resume/sections/Education.astro'
import Interests from '@/components/resume/sections/Interests.astro'
import Activity from '@/components/resume/sections/Activity.astro'

import PrintPageBreak from '@/components/resume/PrintPageBreak.astro'
import { getCollection } from 'astro:content'

const experiences = (await getCollection('resumeExperiences')).filter(
  (e) => e.data.visibility.resume_print,
)
const projects = (await getCollection('resumeProjects'))
  .filter((p) => p.data.visibility.resume_print)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
const activities = await getCollection('resumeActivities')
const skills = await getCollection('resumeSkills')
const educations = (await getCollection('resumeEducations')).filter(
  (e) => e.data.visibility.resume_print,
)
const interestsEntries = await getCollection('resumeInterests')
const interests = interestsEntries[0].data.items

const pageSettingClass = 'px-12 py-4 font-resumesans'
---

<BaseLayoutPrint title={`${SITE.displayName}'s Resume`} description="">
  <WebWrapper className="flex min-h-screen flex-col justify-center">
    <PageLayout className={pageSettingClass}>
      <Content className="mx-auto max-w-[1200px]">
        <div class="col-span-7 mb-2">
          <PrintHeader />
        </div>

        <div class="col-span-2 block block space-y-1">
          <Skills data={skills} variant="print" />
          <Experiences data={experiences} variant="print" />
          <Education data={educations} variant="print" />
          <Projects data={projects} variant="print" />
        </div>
      </Content>
    </PageLayout>

    <PrintPageBreak />

    <PageLayout className={pageSettingClass}>
      <Content className="mx-auto max-w-[1200px]">
        <div class="col-span-5 block space-y-1">
          <Activity data={activities} variant="print" />
          <Interests items={interests} variant="print" />
        </div>
      </Content>
    </PageLayout>
  </WebWrapper>
</BaseLayoutPrint>
