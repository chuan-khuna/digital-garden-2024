---
// import BaseLayoutPrint from '@/layouts/BaseLayoutPrint.astro'
import BaseLayout from '@/layouts/BaseLayout.astro'
// sections
import Experiences from '@/components/resume/sections/Experiences.astro'
import Projects from '@/components/resume/sections/Projects.astro'
import Activity from '@/components/resume/sections/Activity.astro'
import Skills from '@/components/resume/sections/Skills.astro'
import Education from '@/components/resume/sections/Education.astro'
import Interests from '@/components/resume/sections/Interests.astro'
import Now from '@/components/resume/sections/Now.astro'

import { getCollection } from 'astro:content'
import { SITE } from '@/content/site.config.ts'

const headerEntries = await getCollection('resumeHeader')
const header = headerEntries[0].data

const experiences = await getCollection('resumeExperiences')
const projects = (await getCollection('resumeProjects')).sort(
  (a, b) => (a.data.order ?? 0) - (b.data.order ?? 0),
)
const activities = await getCollection('resumeActivities')
const skills = await getCollection('resumeSkills')
const educations = await getCollection('resumeEducations')
const interestsEntries = await getCollection('resumeInterests')
const interests = interestsEntries[0].data.items
const nowEntries = await getCollection('resumeNow')
const nowEntry = nowEntries[0]

const textGrayClasses = 'text-gray-500 dark:text-gray-500'

const ogImageSlug = 'resume'
const ogImageUrl = new URL(`og/pages/${ogImageSlug}.png`, Astro.site)
---

<BaseLayout title={`${SITE.displayName}'s Resume`} description="" ogImage={ogImageUrl}>
  <div class="">
    <!-- resume layout -->
    <div
      class="mx-auto grid max-w-[1200px] grid-cols-1 gap-2 p-2 md:grid-cols-2"
    >
      <!-- header: name and summary -->
      <div class="md:col-span-2" name="header-summary">
        <div class="relative border p-4">
          <div class="md:flex">
            <div>
              <h1 class="text-4xl font-bold">{header.name}</h1>
              <p class=`${textGrayClasses} text-xl`>{header.jobTitle}</p>
            </div>
          </div>
          <div class="mt-4 md:flex">
            <div name="summary">
              <p>
                {header.introduction}
              </p>
            </div>
            <div
              class="mt-4 w-full max-w-[400px] md:mt-0 md:pl-8 md:text-right"
              name="contact-info"
            >
              <p>
                <span class="font-medium">Github</span>:
                <a
                  href={header.github}
                  target="_blank"
                  rel="noreferrer"
                  class="underline"
                >
                  {header.githubName}
                </a>
              </p>
              <p>
                <span class="font-medium">Email</span>: {header.email}
              </p>
              <p>
                <span class="font-medium">Location</span>: {header.location}
              </p>
            </div>
          </div>
        </div>
      </div>
      <!-- detail -->
      <div class="block space-y-2" name="detail-left">
        <Experiences data={experiences} />
        <Projects data={projects} />
        <Activity data={activities} />
      </div>
      <div class="block space-y-2" name="detail-right">
        <Skills data={skills} />
        <Education data={educations} />
        <Interests items={interests} />
        <Now data={nowEntry} />
        <div class="block border p-4">
          <a href="/resume-print" class="font-medium underline">
            Resume - Print version
          </a>
          <br />
          <a href="/cv-print" class="font-medium underline">
            CV - Print version
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
