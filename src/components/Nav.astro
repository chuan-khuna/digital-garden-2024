---
import ThemeToggle from '@/components/ThemeToggle.astro'
import { Button } from '@/components/ui/button'
import { Menu, X as Close } from 'lucide-react'
import { getCollection } from 'astro:content'
import Logo from '@/components/Logo.astro'

const navItems = await getCollection('navItems')
const sortedNavItems = navItems.sort((a, b) => a.data.order - b.data.order)

const currentPath = Astro.url.pathname
---

<header class="sticky top-0 z-50 w-full print:hidden">
  <!-- FT top accent stripe -->
  <!-- <div class="bg-foreground h-[3px] w-full"></div> -->

  <!-- Main nav bar -->
  <div class="border-border bg-background border-b">
    <div
      class="mx-auto flex h-10 max-w-[1440px] items-stretch justify-between px-4"
    >
      <!-- Logo -->
      <!-- <div class="flex shrink-0 items-center pr-4">
        <a href="/" class="flex items-center">
          <Logo />
        </a>
      </div> -->

      <!-- Desktop nav: items stretch full height, active gets colored bottom border -->
      <nav
        id="desktop-nav"
        class="hidden flex-1 items-stretch justify-end md:flex"
      >
        {
          sortedNavItems.map((item) => {
            const isActive =
              item.data.link === '/'
                ? currentPath === '/'
                : currentPath.startsWith(item.data.link)
            return (
              <a
                href={item.data.link}
                class={[
                  'flex items-center border-b-[2px] px-2 text-xs font-bold uppercase tracking-[0.05em] transition-colors',
                  isActive
                    ? 'border-primary text-foreground'
                    : 'text-foreground/55 hover:text-foreground border-transparent',
                ].join(' ')}
              >
                {item.data.label}
              </a>
            )
          })
        }
      </nav>

      <!-- Right controls -->
      <div class="flex shrink-0 items-center gap-1">
        <div class="bg-border mx-2 hidden h-4 w-px md:block"></div>
        <ThemeToggle />
        <div id="mobile-nav-buttons" class="flex md:hidden">
          <Button variant="ghost" size="icon" id="mobile-nav">
            <Menu className="h-[1.2rem] w-[1.2rem]" id="nav-hamburger" />
            <Close className="hidden h-[1.2rem] w-[1.2rem]" id="nav-close" />
          </Button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile nav -->
  <div
    id="mobile-nav-container"
    class="border-border bg-background hidden w-full border-b"
  >
    <div class="flex flex-col md:hidden">
      {
        sortedNavItems.map((item) => {
          const isActive =
            item.data.link === '/'
              ? currentPath === '/'
              : currentPath.startsWith(item.data.link)
          return (
            <a
              href={item.data.link}
              class={[
                'border-border border-b px-4 py-3 text-xs font-bold uppercase tracking-[0.1em] last:border-b-0',
                isActive
                  ? 'text-foreground'
                  : 'text-foreground/55 hover:text-foreground',
              ].join(' ')}
            >
              {item.data.label}
            </a>
          )
        })
      }
    </div>
  </div>
</header>

<script>
  const mobileNavContainer = document.getElementById('mobile-nav-container')
  const navButton = document.getElementById('mobile-nav')
  const hamburgerIcon = document.getElementById('nav-hamburger')
  const closeIcon = document.getElementById('nav-close')

  const handleNavClick = () => {
    hamburgerIcon.classList.toggle('hidden')
    closeIcon.classList.toggle('hidden')
    mobileNavContainer.classList.toggle('hidden')
  }

  navButton.addEventListener('click', handleNavClick)
</script>
