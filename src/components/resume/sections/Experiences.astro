---
import SectionBlock from '../SectionBlock.astro'
import UnorderedList from '../UnorderedList.astro'
import Item from '@/components/resume/Item/Item.astro'
import { getCollection } from 'astro:content'

const experiences = await getCollection('resumeExperiences')
---

<SectionBlock title="Experience">
  {
    experiences.map((experience) => (
      <div>
        <Item
          title={experience.data.jobTitle}
          timeDescription={experience.data.time}
          description={experience.data.company}
        />
        <UnorderedList ulClass="text-sm" items={experience.data.details} />
      </div>
    ))
  }
</SectionBlock>