---
import SectionBlock from '../SectionBlock.astro'
import UnorderedList from '../UnorderedList.astro'
import { getCollection } from 'astro:content'

const interestsEntries = await getCollection('resumeInterests')
const interests = interestsEntries[0].data.items
---

<SectionBlock title="Interests">
  <UnorderedList ulClass="text-sm" items={interests} />
</SectionBlock>