---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintItem from '@/components/resume/Item/PrintItem.astro'
import PrintUnorderedList from '@/components/resume/PrintUnorderedList.astro'
import { getCollection } from 'astro:content'

const activities = await getCollection('resumeActivities')
---

<PrintSectionBlock title="Activity">
  {
    activities.map((activity) => (
      <>
        <PrintItem
          title={activity.data.title}
          timeDescription={activity.data.time}
          description={activity.data.description}
          titleFontSize="sm"
        />
        <PrintUnorderedList items={activity.data.details} />
      </>
    ))
  }
</PrintSectionBlock>