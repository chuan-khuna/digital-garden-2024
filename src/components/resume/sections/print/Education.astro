---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintItem from '@/components/resume/Item/PrintItem.astro'
import PrintUnorderedList from '@/components/resume/PrintUnorderedList.astro'
import { getCollection } from 'astro:content'

const educations = await getCollection('resumeEducations')
const printEducations = educations.filter((e) => e.data.visibility.resume_print)
---

<PrintSectionBlock title="Education">
  {
    printEducations.map((education) => (
      <>
        <PrintItem
          title={education.data.degree}
          timeDescription={education.data.time}
          description={education.data.institution}
        />
        <PrintUnorderedList items={education.data.details} />
      </>
    ))
  }
</PrintSectionBlock>