---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintItem from '@/components/resume/Item/PrintItem.astro'
import PrintUnorderedList from '@/components/resume/PrintUnorderedList.astro'
import { getCollection } from 'astro:content'

const experiences = await getCollection('resumeExperiences')
const printExperiences = experiences.filter((e) => e.data.visibility.resume_print)
---

<PrintSectionBlock title="Experiences">
  {
    printExperiences.map((experience) => (
      <>
        <PrintItem
          title={experience.data.jobTitle}
          timeDescription={experience.data.time}
          description={experience.data.company}
        />
        <PrintUnorderedList items={experience.data.details} />
      </>
    ))
  }
</PrintSectionBlock>