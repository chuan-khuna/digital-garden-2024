---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintItem from '@/components/resume/Item/PrintItem.astro'
import ResumeMarkdownBulletWrapper from '@/components/resume/ResumeMarkdownBulletWrapper.astro'
import { getCollection, render } from 'astro:content'

const experiences = await getCollection('resumeExperiences')
const printExperiences = experiences.filter((e) => e.data.visibility.resume_print)
const renderedExperiences = await Promise.all(
  printExperiences.map(async (exp) => {
    const { Content } = await render(exp)
    return { exp, Content }
  }),
)
---

<PrintSectionBlock title="Experiences">
  {
    renderedExperiences.map(({ exp, Content }) => (
      <>
        <PrintItem
          title={exp.data.jobTitle}
          timeDescription={exp.data.time}
          description={exp.data.company}
        />
        <ResumeMarkdownBulletWrapper variant="print">
          <Content />
        </ResumeMarkdownBulletWrapper>
      </>
    ))
  }
</PrintSectionBlock>