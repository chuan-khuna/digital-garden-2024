---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintItem from '@/components/resume/Item/PrintItem.astro'
import PrintUnorderedList from '@/components/resume/PrintUnorderedList.astro'
import { getCollection } from 'astro:content'

const projects = await getCollection('resumeProjects')
const printProjects = projects.filter((p) => p.data.visibility.resume_print)
---

<PrintSectionBlock title="Projects">
  {
    printProjects.map((project) => (
      <>
        <PrintItem
          title={project.data.title}
          timeDescription={project.data.time}
          description={project.data.description}
          url={project.data.url}
        />
        <PrintUnorderedList items={project.data.details} />
      </>
    ))
  }
</PrintSectionBlock>