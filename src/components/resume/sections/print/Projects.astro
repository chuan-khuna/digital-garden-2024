---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintItem from '@/components/resume/Item/PrintItem.astro'
import ResumeMarkdownBulletWrapper from '@/components/resume/ResumeMarkdownBulletWrapper.astro'
import { getCollection, render } from 'astro:content'

const projects = await getCollection('resumeProjects')
const printProjects = projects
  .filter((p) => p.data.visibility.resume_print)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0))
const renderedProjects = await Promise.all(
  printProjects.map(async (project) => {
    const { Content } = await render(project)
    return { project, Content }
  }),
)
---

<PrintSectionBlock title="Projects">
  {
    renderedProjects.map(({ project, Content }) => (
      <>
        <PrintItem
          title={project.data.title}
          timeDescription={project.data.time}
          description={project.data.description}
          url={project.data.url}
        />
        <ResumeMarkdownBulletWrapper variant="print">
          <Content />
        </ResumeMarkdownBulletWrapper>
      </>
    ))
  }
</PrintSectionBlock>