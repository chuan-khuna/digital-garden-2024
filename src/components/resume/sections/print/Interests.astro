---
import PrintSectionBlock from '@/components/resume/PrintSectionBlock.astro'
import PrintUnorderedList from '@/components/resume/PrintUnorderedList.astro'
import { getCollection } from 'astro:content'

const interestsEntries = await getCollection('resumeInterests')
const interests = interestsEntries[0].data.items
---

<PrintSectionBlock title="Interests">
  <PrintUnorderedList items={interests} />
</PrintSectionBlock>